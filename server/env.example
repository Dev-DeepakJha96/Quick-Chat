# Server configuration 
NODE_ENV=development
PORT=5000

# Client URLs (comma-separated list of origins allowed by CORS)
CLIENT_URL=http://localhost:5173

# Database 
MONGODB_URI=mongodb://localhost:27017/chat_app
MONGODB_OPTIONS_RETRY_WRITES=true
MONGODB_OPTIONS_MAX_POOL_SIZE=10

# JWT configuration (use long random strings for secrets)
JWT_ACCESS_SECRET=your_jwt_access_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=12

# Logging
LOG_LEVEL=debug
LOG_FILE_ENABLED=false

# Email (SMTP configuration for verification/reset password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email_username_here
EMAIL_PASS=your_email_app_password_here
